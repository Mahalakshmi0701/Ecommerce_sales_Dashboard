        "# =========================\n",
        "# IMPORT LIBRARIES\n",
        "# =========================\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# =========================\n",
        "# UPLOAD CSV\n",
        "# =========================\n",
        "from google.colab import files\n",
        "uploaded = files.upload()\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "file_name = list(uploaded.keys())[0]\n",
        "df = pd.read_csv(file_name)\n",
        "\n",
        "df.head()\n",
        "\n",
        "print(\"First 5 rows:\")\n",
        "print(df.head())\n",
        "\n",
        "# =========================\n",
        "# DATA CLEANING\n",
        "# =========================\n",
        "df = df.drop_duplicates()\n",
        "\n",
        "df['ProductName'] = df['ProductName'].fillna(\"Unknown\")\n",
        "df['Category'] = df['Category'].fillna(\"Unknown\")\n",
        "df['Brand'] = df['Brand'].fillna(\"Unknown\")\n",
        "\n",
        "df['Price'] = pd.to_numeric(df['Price'], errors='coerce')\n",
        "df['Rating'] = pd.to_numeric(df['Rating'], errors='coerce')\n",
        "df['StockQuantity'] = pd.to_numeric(df['StockQuantity'], errors='coerce')\n",
        "\n",
        "df['Price'].fillna(df['Price'].median(), inplace=True)\n",
        "df['Rating'].fillna(df['Rating'].mean(), inplace=True)\n",
        "df['StockQuantity'].fillna(0, inplace=True)\n",
        "\n",
        "df = df[df['Price'] > 0]\n",
        "df = df[df['Rating'].between(0, 5)]\n",
        "\n",
        "# =========================\n",
        "# EDA\n",
        "# =========================\n",
        "print(\"\\nBasic Stats:\")\n",
        "print(df.describe())\n",
        "\n",
        "print(\"\\nTop Categories:\")\n",
        "print(df['Category'].value_counts())\n",
        "\n",
        "print(\"\\nAvg Price by Category:\")\n",
        "print(df.groupby(\"Category\")[\"Price\"].mean())\n",
        "\n",
        "# =========================\n",
        "# VISUALS\n",
        "# =========================\n",
        "plt.hist(df['Price'])\n",
        "plt.title(\"Price Distribution\")\n",
        "plt.show()\n",
        "\n",
        "plt.hist(df['Rating'])\n",
        "plt.title(\"Rating Distribution\")\n",
        "plt.show()\n",
        "\n",
        "df.groupby(\"Category\")[\"Rating\"].mean().plot(kind=\"bar\")\n",
        "plt.title(\"Avg Rating by Category\")\n",
        "plt.show()\n",
        "\n",
        "# =========================\n",
        "# INSIGHTS\n",
        "# =========================\n",
        "print(\"\\nHigh Price Low Rating:\")\n",
        "print(df[(df['Price'] > 2000) & (df['Rating'] < 3.5)])\n",
        "\n",
        "print(\"\\nBest Value Products:\")\n",
        "print(df[(df['Price'] < 500) & (df['Rating'] > 4.5)])\n",
        "\n",
        "# =========================\n",
        "# SAVE CLEAN DATA\n",
        "# =========================\n",
        "df.to_csv(\"cleaned_products.csv\", index=False)\n",
        "\n",
        "print(\"\\n✅ Done! Cleaned file saved.\")"
